# Terraform local working directory and provider cache
.terraform/

# Terraform state files (can contain sensitive metadata)
*.tfstate
*.tfstate.*
*.tfplan

# Terraform crash logs
crash.log
crash.*.log

# Variable files often contain secrets and environment-specific values
*.tfvars
*.tfvars.json

# Local override files should not be committed
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock info and CLI local config files
.terraform.tfstate.lock.info
.terraformrc
terraform.rc

# Local environment files and key material
.env
.env.local
.env.*.local
*.pem
*.key
